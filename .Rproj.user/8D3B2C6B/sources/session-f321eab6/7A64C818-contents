\begin{problem}
  Explain how a node in a graph that has both incoming and outgoing edges can end up in a DFS tree by itself.  Draw an example of a graph and DFS forest where this happens.
\end{problem}


\begin{problem}
Give a counterexample to disprove the following claim:
\begin{claim} 
If a directed graph $G = (V,E)$ contains a path from $u$ to $v$, for some $u,v\in V$, then any depth-first search must result in $discovered[v] \leq finished[u]$.  That is, $v$ must always be discovered before $u$ is finished.
\end{claim}
\end{problem}

\begin{problem}
Prove that a connected graph with unique edge weights (no two edges have the same weight) has exactly one MST.  {\em (Hint: See the proof of correctness for Kruskal's algorithm.)}
\end{problem}

\begin{problem}
Consider the following topological sort algorithm: Repeatedly find a node with no incoming edges, put it at the head of the output list, and remove it and all edges outgoing from it from the graph.  When done, output the list as a topological sort.  Explain how to implement this algorithm in $O(|V|+|E|)$ time.  What happens if you run this algorithm on a graph with a cycle?
\end{problem}

\begin{problem}
  Prove that the lightest edge in a graph is in some minimum spanning tree of the graph.
\end{problem}

